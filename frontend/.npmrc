# Strict peer-dep checking surfaces real version drift; the install
# already prints WARN for incidental peer mismatches we accept.
strict-peer-dependencies=false

# pnpm build-script approvals (sharp / unrs-resolver = ignored) live in
# pnpm-workspace.yaml; in pnpm 11 the `pnpm.onlyBuiltDependencies` field
# in package.json is no longer read.
