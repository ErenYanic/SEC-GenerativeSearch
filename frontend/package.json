{
  "name": "sec-generative-search-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "SEC-GenerativeSearch web UI — strict-CSP / Trusted-Types SPA.",
  "packageManager": "pnpm@11.2.2",
