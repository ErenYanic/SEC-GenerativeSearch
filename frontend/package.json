    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.10.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "9.18.0",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.1.0",
    "happy-dom": "16.7.2",
    "postcss": "8.5.15",
